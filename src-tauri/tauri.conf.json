{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../ui",
    "distDir": "../ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "WOW Fishing UI",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.wow.fishing-ui",
      "externalBin": [
        "binaries/WowFishingBot"
      ]
    },
    "windows": [
      {
        "title": "WOW 自动钓鱼",
        "width": 1300,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "allowlist": {
      "all": true
    }
  }
}
